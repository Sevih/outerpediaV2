{
  "name": "outerpedia-v2",
  "version": "3.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx scripts/dev-with-images.ts",
    "dev:next": "next dev",
    "set-version": "node scripts/set-version.js",
    "build": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\" && npm run set-version && npm run images && npm run pipeline -- --prod && next build",
    "start": "next start",
    "lint": "eslint",
    "pipeline": "tsx pipeline/run.ts",
    "pipeline:step": "tsx pipeline/run.ts --step",
    "pipeline:validate": "tsx pipeline/run.ts --validate",
    "images": "tsx scripts/convert-images.ts",
    "images:watch": "tsx scripts/convert-images.ts --watch",
    "commit": "node scripts/commit.mjs",
    "commit:fast": "node scripts/commit.mjs --skip-build"
  },
  "dependencies": {
    "@radix-ui/react-hover-card": "1.1.15",
    "cheerio": "^1.2.0",
    "iconv-lite": "^0.7.2",
    "keen-slider": "^6.8.6",
    "lz-string": "1.5.0",
    "next": "16.1.7",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-icons": "5.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/lz-string": "1.3.34",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.7",
    "sharp": "0.34.5",
    "tailwindcss": "^4",
    "tsx": "4.21.0",
    "typescript": "^5"
  }
}
